<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <Exclude>
            [WeatherApp.Api]WeatherApp.Api.Models.*,
            [WeatherApp.Api]Program,
            [WeatherApp.Api]Microsoft.AspNetCore.OpenApi.Generated.*
          </Exclude>
          <ExcludeByFile>**/Program.cs</ExcludeByFile>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
